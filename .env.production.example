# Typring production environment variables
#
# Copy these values into Vercel Project Settings > Environment Variables.
# Do not commit real secrets.

# Supabase
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key

# App
NEXT_PUBLIC_APP_URL=https://your-production-domain.example

# X/Twitter OAuth
# These are configured in Supabase Auth provider settings.
# Keep them out of browser code.
TWITTER_CLIENT_ID=your_x_client_id
TWITTER_CLIENT_SECRET=your_x_client_secret

# Ads
NEXT_PUBLIC_ENABLE_ADS=false
NEXT_PUBLIC_ADSENSE_CLIENT_ID=
NEXT_PUBLIC_ADSENSE_HOME_SLOT=
NEXT_PUBLIC_ADSENSE_SEARCH_SLOT=
NEXT_PUBLIC_ADSENSE_PROFILE_SLOT=
NEXT_PUBLIC_ADSENSE_HANDBOOK_SLOT=

# AI compatibility
# Leave empty for beta if you do not want AI compatibility to generate results.
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
