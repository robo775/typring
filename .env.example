# Typring environment variables

# Supabase
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
# Server-only. Never expose this value to the browser.
SUPABASE_SERVICE_ROLE_KEY=

# App
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Auth
# Configure X/Twitter OAuth in the Supabase dashboard.
# Do not expose provider secrets to the browser.
TWITTER_CLIENT_ID=
TWITTER_CLIENT_SECRET=

# Ads
NEXT_PUBLIC_ENABLE_ADS=false
NEXT_PUBLIC_ADSENSE_CLIENT_ID=
NEXT_PUBLIC_ADSENSE_HOME_SLOT=
NEXT_PUBLIC_ADSENSE_SEARCH_SLOT=
NEXT_PUBLIC_ADSENSE_PROFILE_SLOT=
NEXT_PUBLIC_ADSENSE_HANDBOOK_SLOT=

# Future AI features
OPENAI_API_KEY=
OPENAI_MODEL=
